# Frontend (Vite / Netlify)
VITE_ACADEMY_CONTACT_EMAIL=academy@example.com
VITE_ADMIN_CC_EMAIL=admin-cc@example.com

# Existing required frontend env vars (already used in app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_WEB_PUSH_PUBLIC_KEY=your-web-push-public-key

# Optional frontend env vars
# VITE_GOOGLE_MAPS_API_KEY=AIza...
# VITE_APP_VERSION=6.0.0
# VITE_ENABLE_GTM_DEBUG=false
# VITE_ENABLE_PERF_DEBUG=false
# VITE_ENABLE_PAGEVIEW_DEBUG=false
# VITE_ENABLE_SW_DEBUG=false

# Backend (Supabase Edge Functions secrets)
# Set with: supabase secrets set KEY=value
ACADEMY_CONTACT_EMAIL=academy@example.com
ADMIN_CC_EMAIL=admin-cc@example.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
SMOKE_TEST_RECIPIENT=ops@example.com
EMAIL_SMOKE_TEST_KEY=change-this-shared-secret
